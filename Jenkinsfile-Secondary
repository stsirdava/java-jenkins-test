pipeline {
    agent any

    triggers {
        upstream(
            upstreamProjects: 'QA-Automation-Pipeline',
            threshold: hudson.model.Result.FAILURE
        )
    }

    stages {
        stage('Fetch Artifacts & Publish Reports') {
            steps {
                copyArtifacts(
                    projectName: 'QA-Automation-Pipeline',
                    filter: 'target/allure-results/**, custom-report/index.html',
                    selector: lastCompleted()
                )

                junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'

                allure(
                    results: [[path: 'target/allure-results']]
                )
            }
        }
    }

    post {
        always {
            echo 'Publishing HTML Report...'

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'custom-report',
                reportFiles: 'index.html',
                reportName: 'Demo HTML Report'
            ])
        }
    }
}